# Auth.js / NextAuth — required
# Generate: openssl rand -base64 32  (or https://generate-secret.vercel.app/32)
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Account that receives admin role (must match Google sign-in email)
ADMIN_EMAIL=you@example.com

# Admin API header x-admin-secret (scripts/seed-demo-edition.mjs, automation)
ADMIN_SECRET=

# Reader HMAC cookie (defaults to ADMIN_SECRET, then a dev placeholder)
# READER_SECRET=

# Vercel Blob — omit for local storage/ only
# BLOB_READ_WRITE_TOKEN=

# Optional: canonical URL prefix for magazine asset links
# CDN_URL=https://your-domain.com
# NEXT_PUBLIC_CDN_URL=https://your-domain.com

# Used by scripts/seed-demo-edition.mjs when dev server is not on :3000
# BASE_URL=http://localhost:3000
