# Auth.js / NextAuth — required
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin login at /admin (email + password)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vercel Blob Storage (required in production for users + PDFs)
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Admin API header x-admin-secret (optional automation)
ADMIN_SECRET=

# Reader session signing (optional; falls back to AUTH_SECRET)
READER_SECRET=

# Optional: canonical URL prefix for magazine asset links
# CDN_URL=https://your-domain.com
# NEXT_PUBLIC_CDN_URL=https://your-domain.com

# Used by scripts/seed-demo-edition.mjs when dev server is not on :3000
# BASE_URL=http://localhost:3000
